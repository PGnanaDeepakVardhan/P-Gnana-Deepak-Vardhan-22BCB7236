create database thursday;
show databases;

use thursday;
create table category(
c_id int primary key,
c_name varchar(25),
c_details varchar(25)
);

insert into category values(201,'clothing','men and women');
insert into category values(202,'kitchen appliances','cookware and tools');

select * from category;

create table products(
p_id int primary key,
p_name varchar(25),
p_details varchar(35),
c_id int,
foreign key products (c_id) references category (c_id) on update cascade
);
drop table products;
desc products;

insert into products values(205, 'mixer','electric mixer 750W',201);
select * from products;

#primary key: is not null, does not accepts duplicates.
#foriegn key: is not null but it does accepts duplicates.
#unkonwn products will not be addedd.

delete from category where c_id =202;
delete from category where c_id =201;

update category set c_id=207 where c_name ='clothing';
# on delete cascade
# on update cascade

#applied above

# adding a unique constraint
# droping a unique constrint
drop database thursday;
use thursday;


alter table products
add constraint unique_id unique (p_id);

alter table products
drop constraint unique_id;

use flipkart;
show tables from flipkart;

alter table employee
add primary key(e_id);

alter table employee
drop primary key;

#foreign key 
use flipkart;
desc customer;
alter table customer 
add primary key (c_id);

alter table seller
add c_id int not null;


desc seller;
alter table seller
add foreign key (c_id) references customer(c_id);

#check constraint
desc employee;
alter table employee 
add check (e_handlingNoOfProjects>0);

#default constraint
alter table employee
add e_country varchar(30) default 'India';

select * from employee;
